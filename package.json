{
  "name": "indiekit-adamsaunders.net",
  "version": "1.0.0",
  "description": "Indiekit server for https://adamsaunders.net",
  "main": "index.js",
  "scripts": {
    "start": "indiekit serve"
  },
  "keywords": [
    "indiekit",
    "indieweb"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "indiekit": {
    "plugins": [
      "@indiekit/preset-jekyll",
      "@indiekit/store-github",
      "@indiekit/syndicator-bluesky",
      "@indiekit/syndicator-mastodon"
    ],
    "publication": {
      "me": "https://adamsaunders.net"
    },
    "@indiekit/store-github": {
      "user": "saundersresearch",
      "repo": "saundersresearch.github.io",
      "branch": "main"
    },
    "@indiekit/syndicator-bluesky": {
      "handle": "adamsaunders.net"
    },
    "@indiekit/syndicator-mastodon": {
      "url": "https://indieweb.social",
      "user": "adamsaunders"
    }
  },
  "dependencies": {
    "@indiekit/indiekit": "^1.0.0-beta.25",
    "@indiekit/preset-jekyll": "^1.0.0-beta.25",
    "@indiekit/store-github": "^1.0.0-beta.25",
    "@indiekit/syndicator-bluesky": "^1.0.0-beta.25",
    "@indiekit/syndicator-mastodon": "^1.0.0-beta.25",
    "dotenv": "^17.3.1"
  }
}
